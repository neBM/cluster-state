{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    ":automergeMinor",
    ":semanticCommits",
    ":dependencyDashboard"
  ],
  "timezone": "Europe/London",
  "labels": [
    "dependencies"
  ],
  "packageRules": [
    {
      "description": "Group Flux controller image updates from the bootstrap kustomization",
      "matchManagers": [
        "kustomize"
      ],
      "matchDatasources": [
        "docker"
      ],
      "matchFileNames": [
        "clusters/k3s-homelab/flux-system/kustomization.yaml"
      ],
      "groupName": "flux-controllers",
      "labels": [
        "flux",
        "kubernetes",
        "dependencies"
      ]
    },
    {
      "description": "Group Kustomize image updates",
      "matchManagers": [
        "kustomize"
      ],
      "matchDatasources": [
        "docker"
      ],
      "matchFileNames": [
        "apps/**/kustomization.yaml",
        "infrastructure/**/kustomization.yaml"
      ],
      "groupName": "k8s-images",
      "labels": [
        "kubernetes",
        "docker",
        "dependencies"
      ]
    },
    {
      "description": "Group GitLab CNG replacement-managed release values",
      "matchManagers": [
        "custom.regex"
      ],
      "matchFileNames": [
        "apps/gitlab/kustomization.yaml"
      ],
      "groupName": "gitlab-cng",
      "labels": [
        "gitlab",
        "docker",
        "dependencies"
      ]
    },
    {
      "description": "Group Dockerfile base image updates",
      "matchManagers": [
        "dockerfile"
      ],
      "groupName": "build-images",
      "labels": [
        "docker",
        "dependencies"
      ]
    },
    {
      "description": "Group Go module updates for the SeaweedFS CSI driver",
      "matchManagers": [
        "gomod"
      ],
      "matchFileNames": [
        "drivers/seaweedfs-csi-driver/**"
      ],
      "groupName": "seaweedfs csi driver go modules",
      "groupSlug": "seaweedfs-csi-driver-go-modules",
      "labels": [
        "go",
        "dependencies"
      ]
    },
    {
      "description": "Group Go module updates for the RPi5 DRA driver",
      "matchManagers": [
        "gomod"
      ],
      "matchFileNames": [
        "drivers/rpi5-dra-driver/**"
      ],
      "groupName": "rpi5 dra driver go modules",
      "groupSlug": "rpi5-dra-driver-go-modules",
      "labels": [
        "go",
        "dependencies"
      ]
    },
    {
      "description": "Keep v1alpha1 COSI forks pinned to the release-0.2-compatible dependency set",
      "matchManagers": [
        "gomod"
      ],
      "matchFileNames": [
        "drivers/cosi-provisioner-sidecar/**",
        "drivers/seaweedfs-cosi-driver/**"
      ],
      "enabled": false
    },
    {
      "description": "Separate major updates from minor/patch",
      "matchUpdateTypes": [
        "major"
      ],
      "labels": [
        "major-update"
      ],
      "automerge": false
    },
    {
      "description": "Auto-merge patch updates",
      "matchUpdateTypes": [
        "patch"
      ],
      "automerge": true
    }
  ],
  "customManagers": [
    {
      "customType": "regex",
      "description": "Update GitLab CNG app and migration versions used by Kustomize replacements",
      "managerFilePatterns": [
        "/^apps/gitlab/kustomization\\.yaml$/"
      ],
      "matchStrings": [
        "# renovate: datasource=(?<datasource>[a-zA-Z0-9._-]+) depName=(?<depName>[^\\s]+)\\s+- (?:appVersion|migrationVersion)=(?<currentValue>[^\\s]+)"
      ],
      "versioningTemplate": "docker"
    }
  ],
  "ignoreDeps": [],
  "vulnerabilityAlerts": {
    "enabled": true,
    "labels": [
      "security"
    ]
  }
}
